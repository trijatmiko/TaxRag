    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.user_vocabularies (user_id, vocabulary_id, session_id, is_mastered)\nVALUES (\n  '{{ $json.user_id }}',\n  '{{ $json.vocabulary_id }}',\n  '{{ $json.session_id }}',\n  false\n)\nON CONFLICT (user_id, session_id, vocabulary_id) DO NOTHING\nRETURNING id, user_id, vocabulary_id, session_id, is_mastered, created_at;",
        "options": {}
      },
      "id": "464b81be-ea99-4964-b417-5727169ec2ba",
