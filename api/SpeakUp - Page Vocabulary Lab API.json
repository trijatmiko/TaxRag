        "query": "-- Step 1: Update vocabularies table (shared data)\nUPDATE public.vocabularies\nSET\n  vocab_word     = COALESCE(NULLIF('{{ $json.body.vocab_word }}', ''), vocab_word),\n  part_of_speech = COALESCE(NULLIF('{{ $json.body.part_of_speech }}', ''), part_of_speech),\n  level          = COALESCE(NULLIF('{{ $json.body.level }}', ''), level),\n  definition     = COALESCE(NULLIF('{{ $json.body.definition }}', ''), definition),\n  pronunciation  = COALESCE(NULLIF('{{ $json.body.pronunciation }}', ''), pronunciation),\n  meaning_id     = COALESCE(NULLIF('{{ $json.body.meaning_id }}', ''), meaning_id)\nWHERE id = '{{ $json.body.vocabulary_id }}'\nRETURNING id, vocab_word, part_of_speech, level, definition, pronunciation, meaning_id;",
