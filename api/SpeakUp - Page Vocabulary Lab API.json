    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Step 1: Upsert ke tabel vocabularies (shared, bukan per-user)\n-- Menggunakan index LOWER karena constraint lama sudah diganti dengan unique index case-insensitive\nINSERT INTO public.vocabularies (vocab_word, part_of_speech, level, definition, pronunciation, meaning_id)\nVALUES (\n  '{{ $json.body.vocab_word }}',\n  '{{ $json.body.part_of_speech || \"NOUN\" }}',\n  '{{ $json.body.level || \"B1\" }}',\n  '{{ $json.body.definition || \"\" }}',\n  '{{ $json.body.pronunciation || \"\" }}',\n  '{{ $json.body.meaning_id || \"\" }}'\n)\nON CONFLICT (LOWER(vocab_word)) DO UPDATE\n  SET definition     = EXCLUDED.definition,\n      part_of_speech = EXCLUDED.part_of_speech,\n      pronunciation  = COALESCE(NULLIF(EXCLUDED.pronunciation, ''), vocabularies.pronunciation),\n      meaning_id     = COALESCE(NULLIF(EXCLUDED.meaning_id, ''), vocabularies.meaning_id)\nRETURNING id, vocab_word, part_of_speech, level, definition, pronunciation, meaning_id, created_at;",
        "options": {}
      },
      "id": "859d4196-2d96-463e-a9ec-459e568b1c29",
      "name": "Postgres: Upsert Vocabulary",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -496,
        2656
      ],
      "credentials": {
        "postgres": {
          "id": "Smbm5jUOReBn9ZeS",
          "name": "Postgres account English AI"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH existing_session AS (\n  SELECT id FROM public.sessions\n  WHERE user_id = '{{ $('Webhook: POST /vocabulary/add').item.json.body.user_id }}'\n    AND ended_at IS NULL\n  ORDER BY started_at DESC\n  LIMIT 1\n),\nnew_session AS (\n  INSERT INTO public.sessions (user_id, topic, level)\n  SELECT\n    '{{ $('Webhook: POST /vocabulary/add').item.json.body.user_id }}',\n    'Manual Entry',\n    '{{ $('Webhook: POST /vocabulary/add').item.json.body.level || \"B1\" }}'\n  WHERE NOT EXISTS (SELECT 1 FROM existing_session)\n  RETURNING id\n)\nSELECT id FROM existing_session\nUNION ALL\nSELECT id FROM new_session\nLIMIT 1;",
        "options": {}
      },
      "id": "49587e81-f7b1-42ee-831b-1bd94b30f114",
      "name": "Postgres: Get or Create Session",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -256,
        2656
      ],
      "credentials": {
        "postgres": {
          "id": "Smbm5jUOReBn9ZeS",
          "name": "Postgres account English AI"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const vocabRow   = $('Postgres: Upsert Vocabulary').first().json;\nconst sessionRow = $('Postgres: Get or Create Session').first().json;\nconst body       = $('Webhook: POST /vocabulary/add').first().json.body;\n\nreturn [{\n  json: {\n    user_id:        body.user_id,\n    vocabulary_id:  vocabRow.id,\n    session_id:     sessionRow.id,\n    vocab_word:     vocabRow.vocab_word,\n    part_of_speech: vocabRow.part_of_speech,\n    level:          vocabRow.level,\n    definition:     vocabRow.definition,\n    pronunciation:  vocabRow.pronunciation || '',\n    meaning_id:     vocabRow.meaning_id    || '',\n    created_at:     vocabRow.created_at\n  }\n}];\n"
      },
      "id": "3cc62489-fffa-44a1-ade1-5cfae18d939a",
      "name": "Code: Prepare user_vocab Insert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
