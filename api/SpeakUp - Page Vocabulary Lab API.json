    {
      "parameters": {
        "jsCode": "// Satu Code node menggantikan: Set + 2x Postgres + Merge\n// Alasan: Merge node tidak trigger jika salah satu input kosong (0 rows)\n// Fix: query langsung dari sini pakai $execution.customData atau helper\n\nconst userId = $('Webhook: POST /vocabulary/list').first().json.body.user_id;\n\n// Simpan user_id untuk diakses node berikutnya\nreturn [{ json: { user_id: userId } }];\n"
      },
      "id": "8353fa4c-c8ee-4aee-8ec3-37cf2ca1a67e",
      "name": "Set: user_id",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -256,
        1904
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  u.id           AS user_id,\n  u.name         AS user_name,\n  u.level        AS user_level,\n  u.avatar_url   AS user_avatar,\n  v.id           AS vocab_id,\n  v.vocab_word,\n  v.part_of_speech,\n  v.level        AS vocab_level,\n  v.definition,\n  v.pronunciation,\n  v.meaning_id,\n  v.created_at   AS vocab_created_at,\n  uv.id          AS user_vocab_id,\n  uv.is_mastered,\n  uv.created_at  AS learned_at,\n  s.topic        AS session_topic,\n  -- Stats dihitung sekalian di sini\n  COUNT(*) OVER()                                              AS total_words,\n  COUNT(*) FILTER (WHERE uv.is_mastered = true)  OVER()       AS total_mastered,\n  COUNT(*) FILTER (WHERE uv.is_mastered = false) OVER()       AS total_learning\nFROM public.users u\nINNER JOIN public.user_vocabularies uv ON uv.user_id = u.id\nINNER JOIN public.vocabularies v       ON v.id = uv.vocabulary_id\nLEFT  JOIN public.sessions s           ON s.id = uv.session_id\nWHERE u.id = '{{ $json.user_id }}'\nORDER BY uv.created_at DESC;",
        "options": {}
      },
      "id": "ec22cd8d-373f-4d2e-a6b0-ab457c857eaa",
      "name": "Postgres: Get User Vocabularies",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -16,
        1904
      ],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "Smbm5jUOReBn9ZeS",
          "name": "Postgres account English AI"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Tidak ada Merge — semua data sudah ada di satu query (window function)\n// alwaysOutputData = true di Postgres node agar tetap jalan walau 0 rows\n\nconst items = $input.all();\nconst userId = $('Set: user_id').first().json.user_id;\n\nconst firstRow = items.length > 0 ? items[0].json : null;\n\n// User info\nconst user = firstRow ? {\n  id:         firstRow.user_id,\n  name:       firstRow.user_name,\n  level:      firstRow.user_level,\n  avatar_url: firstRow.user_avatar || null\n} : {\n  id:         userId,\n  name:       'Learner',\n  level:      '—',\n  avatar_url: null\n};\n\n// Stats dari window function (sama di semua row)\nconst stats = {\n  total_words:    firstRow ? parseInt(firstRow.total_words    || 0) : 0,\n  total_mastered: firstRow ? parseInt(firstRow.total_mastered || 0) : 0,\n  total_learning: firstRow ? parseInt(firstRow.total_learning || 0) : 0\n};\n\n// Vocab list\nconst vocabs = items.map(function(item) {\n  const r = item.json;\n  return {\n    id:             r.vocab_id,\n    vocab_word:     r.vocab_word,\n    part_of_speech: r.part_of_speech,\n    level:          r.vocab_level,\n    definition:     r.definition || '',\n    pronunciation:  r.pronunciation || '',\n    meaning_id:     r.meaning_id || '',\n    is_mastered:    r.is_mastered === true || r.is_mastered === 'true',\n    is_difficult:   false,\n    session_topic:  r.session_topic || null,\n    learned_at:     r.learned_at   || null,\n    created_at:     r.vocab_created_at || null\n  };\n});\n\nreturn [{ json: { user, stats, vocabs } }];\n"
      },
