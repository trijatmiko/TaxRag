    {
      "parameters": {
        "jsCode": "const prep = $('Code: Prepare user_vocab Insert').first().json;\nconst uv   = $input.first()?.json || {};\n\nreturn [{\n  json: {\n    id:             prep.vocabulary_id,\n    vocab_word:     prep.vocab_word,\n    part_of_speech: prep.part_of_speech,\n    level:          prep.level,\n    definition:     prep.definition,\n    pronunciation:  prep.pronunciation || '',\n    meaning_id:     prep.meaning_id    || '',\n    is_mastered:    false,\n    is_difficult:   false,\n    learned_at:     uv.created_at || new Date().toISOString(),\n    created_at:     prep.created_at\n  }\n}];\n"
      },
