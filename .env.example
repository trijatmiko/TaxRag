# PostgreSQL
POSTGRES_DB=rag_tax
POSTGRES_USER=raguser
POSTGRES_PASSWORD=your_password_here

# n8n Auth
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password_here

# n8n Network
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Next.js
NEXTJS_PORT=3000
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678/webhook
NEXT_PUBLIC_MINIO_URL=http://localhost:9002
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Opsional — override URL sound effect (default: file di bucket MinIO)
# NEXT_PUBLIC_SOUND_CORRECT_URL=
# NEXT_PUBLIC_SOUND_WRONG_URL=

# n8n Security
N8N_BLOCK_ENV_ACCESS_IN_EXPRESSIONS=false

# ─────────────────────────────────────────
# API Keys (External Providers)
# ─────────────────────────────────────────

# Google Gemini (Legacy / Direct Ingestion)
GEMINI_API_KEY=your_gemini_api_key_here

# Cohere (Reranking / Embedding)
COHERE_API_KEY=your_cohere_api_key_here

# OpenAI (Optional Embedding)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter (Primary Multi-Model Access)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─────────────────────────────────────────
# Model Configuration
# ─────────────────────────────────────────

# Model used for cleaning tax documents during ingestion
# Example: google/gemini-2.5-flash-lite | openai/gpt-4o-mini
OPENROUTER_INGESTION_MODEL=google/gemini-2.5-flash-lite

# Model used for vector embeddings
# Example: openai/text-embedding-3-small | google/text-embedding-004
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
