# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# n8n
N8N_BASIC_AUTH_ACTIVE=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_EMAIL=
N8N_BASIC_AUTH_PASSWORD=
N8N_HOST=
N8N_PORT=
N8N_PROTOCOL=
WEBHOOK_URL=

# ─────────────────────────────────────────
# API Keys — semua kredensial eksternal
# ─────────────────────────────────────────

#
N8N_BLOCK_ENV_ACCESS_IN_EXPRESSIONS=
# Google Gemini (document cleaning & LLM answering)
GEMINI_API_KEY=

# Cohere (embedding + reranking)
COHERE_API_KEY=

# OpenAI — opsional, jika memilih OpenAI sebagai embedding provider
OPENAI_API_KEY=

# OpenRouter — opsional, akses multi-model (LLM ingestion + embedding)

OPENROUTER_INGESTION_KEYS=
OPENROUTER_EMBEDDING_KEYS=

# OpenRouter — opsi alternatif untuk mengakses model bahasa (LLM)
OPENROUTER_API_KEY=

# ─────────────────────────────────────────
# Konfigurasi Model (ubah di sini tanpa menyentuh workflow n8n)
# ─────────────────────────────────────────

# Model untuk clean ingestion via OpenRouter
# Contoh: google/gemini-2.5-flash | deepseek/deepseek-chat-v3-0324 | openai/gpt-4o-mini
OPENROUTER_INGESTION_MODEL=

# Model untuk embedding via OpenRouter
# Contoh: openai/text-embedding-3-small | openai/text-embedding-3-large | google/text-embedding-004
OPENROUTER_EMBEDDING_MODEL=

# Model untuk Synthesis
OPENROUTER_SYNTHESIS_MODEL=

#Google Credentials
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── TAMBAHAN ENGLISH AI ──
OPENROUTER_ENGLISH_MODEL=

#miniO
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Audio Sounds
NEXT_PUBLIC_SOUND_CORRECT_URL=
NEXT_PUBLIC_SOUND_WRONG_URL=

# URL redirect setelah login
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_N8N_BASE_URL=
