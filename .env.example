# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# n8n
N8N_BASIC_AUTH_ACTIVE=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
N8N_HOST=
N8N_PORT=
N8N_PROTOCOL=
WEBHOOK_URL=

# ─────────────────────────────────────────
# API Keys — semua kredensial eksternal
# ─────────────────────────────────────────

# Google Gemini (document cleaning & LLM answering)
GEMINI_API_KEY=

# Cohere (embedding + reranking)
COHERE_API_KEY=

# OpenAI — opsional, jika memilih OpenAI sebagai embedding provider
OPENAI_API_KEY=

# OpenRouter — opsi alternatif untuk mengakses model bahasa (LLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
